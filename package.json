{
  "name": "paynless-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the Paynless backend, shared packages, and apps.",
  "scripts": {
    "dev": "concurrently -k -n web,supabase,netlify -c cyan,green,magenta \"pnpm --filter web dev\" \"supabase functions serve\" \"pnpm --dir netlify dev\"",
    "dev:web": "pnpm --filter ./apps/web dev",
    "build": "pnpm -r --filter @paynless/web... build",
    "build:clean": "pnpm run clean:buildinfo",
    "clean": "pnpm run clean:buildinfo && pnpm run clean:node_modules",
    "clean:buildinfo": "rimraf packages/**/*.tsbuildinfo apps/**/*.tsbuildinfo tsconfig.tsbuildinfo",
    "clean:node_modules": "rimraf node_modules packages/**/node_modules apps/**/node_modules",
    "preview": "pnpm --filter @paynless/web preview",
    "lint": "pnpm -r run lint --if-present",
    "test": "pnpm -r test",
    "test:integration": "vitest run --config ./vitest.config.ts",
    "sync:types": "supabase gen types typescript --local > supabase/functions/types_db.ts && node supabase/scripts/sync-supabase-shared-types.mjs",
    "dev:load-prompts": "cd supabase/functions && deno --allow-all --env=../.env ../scripts/seed_prompt_templates.ts",
    "dev:load-prompts:prod": "cd supabase/functions && deno --allow-all --env=../.env ../scripts/seed_prompt_templates.ts --production"
  },
  "keywords": [
    "supabase",
    "stripe",
    "react",
    "saas"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@google/generative-ai": "^0.24.1",
    "@netlify/async-workloads": "^0.0.106",
    "concurrently": "^9.2.1",
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.1",
    "@supabase/supabase-js": "^2.108.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.42",
    "@vitest/coverage-v8": "1.6.1",
    "@vitest/ui": "^1.6.1",
    "copyfiles": "^2.4.1",
    "dotenv": "^16.6.1",
    "globals": "^15.15.0",
    "jiti": "2.4.2",
    "jsdom": "^26.1.0",
    "msw": "^2.14.6",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^1.6.1"
  }
}
